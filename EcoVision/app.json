{
  "expo": {
    "name": "EcoVision",
    "slug": "ecovision",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2E7D32"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": true },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2E7D32"
      },
      "package": "com.ecovision.app"
    },
    "plugins": [
      [
        "expo-camera",
        { "cameraPermission": "EcoVision needs camera access to scan waste." }
      ]
    ]
  }
}
